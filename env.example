from __future__ import annotations

import json
import os
import threading
import time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.parse import urlparse

from rh_agent.broker import LiveExecutionBlocked
from rh_agent.config import Settings
from rh_agent.execution import TradingEngine
from rh_agent.models import utc_now_iso


class AgentRuntime:
    def __init__(self) -> None:
        self.settings = Settings()
        self.lock = threading.Lock()
        self.last_result: dict = {
            "status": "starting",
            "mode": self.settings.trading_mode,
            "timestamp": utc_now_iso(),
        }
        self.last_error: str | None = None

    def update(self, payload: dict) -> None:
        with self.lock:
            self.last_result = {"timestamp": utc_now_iso(), **payload}
            self.last_error = None

    def error(self, message: str) -> None:
        with self.lock:
            self.last_error = message
            self.last_result = {
                "timestamp": utc_now_iso(),
                "status": "error",
                "mode": self.settings.trading_mode,
                "message": message,
            }

    def snapshot(self) -> dict:
        with self.lock:
            return {
                "service": "robinhood-stock-agent",
                "mode": self.settings.trading_mode,
                "broker": self.settings.broker,
                "live_trading_enabled": self.settings.live_enabled,
                "last_result": self.last_result,
                "last_error": self.last_error,
                "risk_limits": {
                    "max_daily_loss_dollars": self.settings.max_daily_loss_dollars,
                    "max_daily_loss_pct": self.settings.max_daily_loss_pct,
                    "max_position_weight_pct": self.settings.max_position_weight_pct,
                    "max_trades_per_day": self.settings.max_trades_per_day,
                },
            }


runtime = AgentRuntime()


def worker_loop() -> None:
    while True:
        try:
            engine = TradingEngine(Settings())
            result = engine.trade_cycle()
            runtime.update(result)
            print(json.dumps({"event": "worker_cycle", **runtime.snapshot()}), flush=True)
        except LiveExecutionBlocked as exc:
            runtime.error(str(exc))
            print(json.dumps({"event": "worker_blocked", "reason": str(exc)}), flush=True)
        except Exception as exc:  # Keep service alive so Railway health checks still work.
            runtime.error(str(exc))
            print(json.dumps({"event": "worker_error", "reason": str(exc)}), flush=True)
        time.sleep(60 * 60)


class Handler(BaseHTTPRequestHandler):
    def do_GET(self) -> None:
        path = urlparse(self.path).path
        if path in {"/", "/health", "/status"}:
            self._json(200, runtime.snapshot())
            return
        self._json(404, {"error": "not_found", "paths": ["/health", "/status"]})

    def log_message(self, format: str, *args) -> None:
        return

    def _json(self, status: int, payload: dict) -> None:
        body = json.dumps(payload, indent=2, sort_keys=True).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


def main() -> int:
    port = int(os.getenv("PORT", "8080"))
    thread = threading.Thread(target=worker_loop, daemon=True)
    thread.start()
    server = ThreadingHTTPServer(("0.0.0.0", port), Handler)
    print(json.dumps({"event": "web_started", "port": port, "mode": runtime.settings.trading_mode}), flush=True)
    server.serve_forever()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

